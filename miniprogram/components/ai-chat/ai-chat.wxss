/* components/ai-chat/ai-chat.wxss */

.fab {
  position: fixed; right: 32rpx; bottom: 200rpx; z-index: 999;
  width: 96rpx; height: 96rpx; border-radius: 50%;
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  box-shadow: 0 8rpx 28rpx rgba(74,144,217,.45);
  display: flex; align-items: center; justify-content: center;
  animation: pulse 2s infinite;
}
.fab:active { transform: scale(.9); }
.fab-icon { font-size: 48rpx; }
@keyframes pulse {
  0%,100% { box-shadow: 0 8rpx 28rpx rgba(74,144,217,.45); }
  50% { box-shadow: 0 8rpx 40rpx rgba(74,144,217,.65); }
}

.overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,.4); z-index: 1000;
  opacity: 0; visibility: hidden; transition: .25s;
}
.overlay.on { opacity: 1; visibility: visible; }

.panel {
  position: absolute; left: 0; right: 0; bottom: 0; height: 75vh;
  background: #ededed; border-radius: 32rpx 32rpx 0 0;
  display: flex; flex-direction: column;
  transform: translateY(100%); transition: transform .3s ease;
}
.panel.on { transform: translateY(0); }

.head {
  display: flex; align-items: center; padding: 24rpx 30rpx;
  background: #fff; border-radius: 32rpx 32rpx 0 0; flex-shrink: 0;
}
.head-avatar { font-size: 40rpx; margin-right: 14rpx; }
.head-info { flex: 1; }
.head-title { font-size: 32rpx; font-weight: 700; color: #222; display: block; }
.head-sub { font-size: 22rpx; color: #4A90D9; }
.head-close {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: #f0f0f0; display: flex; align-items: center;
  justify-content: center; font-size: 28rpx; color: #999;
}

/* ====== 消息列表 ====== */
.msgs { flex: 1; overflow-y: auto; padding: 24rpx 24rpx 0; }

/* 每条消息行 */
.msg { display: flex; align-items: flex-start; margin-bottom: 28rpx; }

/* AI 消息：左对齐，带头像 */
.msg-left { flex-direction: row; }
.msg-avatar {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  background: linear-gradient(135deg, #e8f0fa, #d0e4f5);
  display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; flex-shrink: 0; margin-right: 14rpx;
}

/* 用户消息：右对齐，右侧留空 */
.msg-right { flex-direction: row-reverse; padding-right: 16rpx; }
.msg-avatar-user {
  margin-right: 0; margin-left: 14rpx;
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  color: #fff;
  font-weight: 700;
}

/* 气泡通用 */
.bub {
  padding: 18rpx 24rpx;
  font-size: 28rpx; line-height: 1.55;
  word-break: break-all;
  position: relative;
}
/* 保证 <text> 内 \\n 显示为换行 */
.bub text {
  white-space: pre-wrap;
}

/* AI 气泡 */
.bub-left {
  background: #fff; border-radius: 6rpx 20rpx 20rpx 20rpx;
  color: #333;
}

/* AI 气泡外层 + 复制按钮 */
.ai-bub-wrap {
  max-width: 72%;
}
.copy-btn {
  align-self: flex-start;
  font-size: 22rpx; color: #999;
  padding: 6rpx 12rpx;
  margin-top: 6rpx;
}
.copy-btn:active {
  color: #4A90D9;
}

/* 用户气泡 */
.bub-right {
  max-width: 72%;
  background: #4A90D9; border-radius: 20rpx 6rpx 20rpx 20rpx;
  color: #fff;
}

/* 加载动画 */
.typing { color: #999; padding: 24rpx 30rpx; }

/* ====== 输入栏 ====== */
.bar {
  display: flex; align-items: center; gap: 14rpx;
  padding: 16rpx 20rpx; background: #f7f7f7;
  border-top: 1rpx solid #e0e0e0; flex-shrink: 0;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}
.bar-input {
  flex: 1; height: 74rpx; background: #fff;
  border-radius: 10rpx; padding: 0 20rpx; font-size: 28rpx;
}
.bar-send {
  font-size: 28rpx; color: #bbb; font-weight: 700;
  padding: 16rpx 10rpx; flex-shrink: 0;
}
.bar-send.has { color: #4A90D9; }
