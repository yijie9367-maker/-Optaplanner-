/** 帖子详情页样式 **/
.page-container {
  padding: 16rpx;
  padding-bottom: 120rpx;
}

/* 帖子卡片 */
.detail-card {
  padding: 32rpx;
}
.detail-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.detail-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #4A90D9;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
}
.detail-author-info {
  flex: 1;
}
.detail-author {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
}
.detail-time {
  font-size: 22rpx;
  color: #999;
}
.detail-pin {
  font-size: 22rpx;
  color: #ff6b6b;
  font-weight: 600;
  background: #fff0f0;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}
.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #191c1e;
  margin-bottom: 20rpx;
  line-height: 1.4;
}
.detail-content {
  font-size: 30rpx;
  color: #444;
  line-height: 1.7;
  margin-bottom: 24rpx;
}
.detail-actions {
  display: flex;
  align-items: center;
  gap: 40rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f2f5;
}
.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.action-item.voted .action-icon {
  filter: none;
}
.action-icon {
  font-size: 32rpx;
}
.action-count {
  font-size: 26rpx;
  color: #999;
}

/* 评论区 */
.comments-section {
  margin-top: 24rpx;
}
.comments-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  padding: 0 8rpx 16rpx;
}
.comment-item {
  display: flex;
  gap: 16rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}
.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #e8f0fa;
  color: #4A90D9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  flex-shrink: 0;
}
.comment-body {
  flex: 1;
}
.comment-top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}
.comment-author {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}
.comment-time {
  font-size: 22rpx;
  color: #bbb;
}
.comment-content {
  font-size: 28rpx;
  color: #444;
  line-height: 1.5;
}
.comments-empty {
  text-align: center;
  color: #bbb;
  padding: 60rpx;
  font-size: 26rpx;
}

/* 底部评论输入 */
.comment-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #e8ecf1;
  box-shadow: 0 -4rpx 12rpx rgba(0,0,0,0.04);
}
.comment-input {
  flex: 1;
  background: #f2f4f7;
  border-radius: 40rpx;
  padding: 18rpx 28rpx;
  font-size: 28rpx;
}
.comment-send {
  font-size: 28rpx;
  color: #4A90D9;
  font-weight: 700;
  padding: 18rpx 16rpx;
}
.comment-send:active {
  opacity: 0.6;
}

/* 禁用态评论栏 */
.comment-bar-disabled {
  opacity: 0.5;
}
.comment-bar-disabled .comment-input {
  color: #bbb;
}
.comment-bar-disabled .comment-send {
  color: #bbb;
}
