/** 课表页面样式 **/
.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 周次选择器 */
.week-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  flex-shrink: 0;
  position: relative;
}
.week-center {
  display: flex;
  align-items: center;
  gap: 32rpx;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}
.week-arrow {
  width: 52rpx;
  height: 52rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #4A90D9;
  box-shadow: 0 2rpx 10rpx rgba(74,144,217,0.1);
  font-weight: bold;
}
.week-arrow:active { background: #e8f0fa; }
.week-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #191c1e;
  min-width: 110rpx;
  text-align: center;
}
.exam-entry {
  font-size: 24rpx; color: #4A90D9; font-weight: 600;
  padding: 10rpx 20rpx; background: #e8f0fa;
  border-radius: 24rpx; flex-shrink: 0;
}
.exam-entry:active { background: #d0e4f5; }
.ai-entry { margin-left: 10rpx; }

/* === 课表网格容器 === */
.schedule-container {
  flex: 1;
  margin: 0 12rpx 12rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(74,144,217,0.07);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  position: relative;
}
.schedule-grid {
  flex: 1;
  display: flex;
  flex-direction: column;
  width: 100%;
}

/* 表头行 */
.grid-header {
  display: flex;
  border-bottom: 2rpx solid #e8ecf1;
  background: #f8fafc;
  flex-shrink: 0;
}
.time-col-header {
  width: 80rpx;
  flex-shrink: 0;
  border-right: 2rpx solid #e8ecf1;
}
.day-col {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0;
  border-right: 1rpx solid #f0f2f5;
  min-width: 0;
}
.day-col:last-child { border-right: none; }
.day-col.today-col {
  background: #e8f0fa;
}
.day-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}
.today-col .day-name {
  color: #4A90D9;
}

/* 数据行 */
.grid-row {
  display: flex;
  flex: 1;
  border-bottom: 1rpx solid #f0f2f5;
}
.grid-row:last-child { border-bottom: none; }

.time-col {
  width: 80rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-right: 2rpx solid #e8ecf1;
  background: #fafbfc;
}
.slot-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #555;
}
.slot-time-top {
  font-size: 16rpx;
  color: #999;
}
.slot-time-bot {
  font-size: 16rpx;
  color: #999;
}

/* 课程单元格 */
.cell {
  flex: 1;
  min-width: 0;
  padding: 4rpx;
  border-right: 1rpx solid #f0f2f5;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
}
.cell:last-child { border-right: none; }
.cell.has-course {
  background: #e8f0fa;
  border-left: 5rpx solid #4A90D9;
  border-radius: 8rpx;
  margin: 3rpx;
  box-shadow: 0 1rpx 4rpx rgba(74,144,217,0.1);
}
.cell.has-course:active {
  transform: scale(0.96);
  opacity: 0.85;
}
.cell.empty-cell { background: #fafbfc; }
.cell.weekend-cell { background: #f5f6f8; }

.course-name {
  font-size: 20rpx;
  font-weight: 700;
  color: #1a3a5c;
  display: block;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.course-location {
  font-size: 18rpx;
  color: #5a7a9a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 2rpx;
}

/* 视图切换 */
.view-toggle {
  display: flex;
  justify-content: center;
  margin: 16rpx;
  background: #e8ecf1;
  border-radius: 32rpx;
  padding: 4rpx;
  width: fit-content;
  margin-left: auto;
  margin-right: auto;
  flex-shrink: 0;
}
.toggle-btn {
  padding: 10rpx 36rpx;
  border-radius: 28rpx;
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}
.toggle-btn.active {
  background: #fff;
  color: #4A90D9;
  font-weight: 700;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.06);
}

/* === 列表视图 === */
.list-view {
  flex: 1;
  padding: 0 12rpx;
  overflow-y: auto;
}
.list-day {
  margin-bottom: 20rpx;
}
.list-day-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  padding: 12rpx 8rpx;
  border-bottom: 2rpx solid #e8ecf1;
  margin-bottom: 10rpx;
}
.list-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.list-item-left {
  width: 160rpx;
  flex-shrink: 0;
}
.list-item-time {
  font-size: 22rpx;
  color: #4A90D9;
  font-weight: 600;
}
.list-item-right {
  flex: 1;
  min-width: 0;
}
.list-item-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #333;
  display: block;
}
.list-item-location {
  font-size: 22rpx;
  color: #888;
  margin-top: 4rpx;
}
.list-empty {
  text-align: center;
  color: #bbb;
  padding: 24rpx;
  font-size: 24rpx;
}

/* === 课程详情弹窗 === */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.35);
  backdrop-filter: blur(6rpx);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
  padding: 32rpx;
}
.modal-mask.show { opacity: 1; visibility: visible; }
.modal-content {
  width: 100%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 36rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.15);
}
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 28rpx;
}
.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #4A90D9;
  flex: 1;
}
.modal-credits {
  background: #e8f0fa;
  color: #4A90D9;
  padding: 6rpx 18rpx;
  border-radius: 32rpx;
  font-size: 22rpx;
  font-weight: 600;
  white-space: nowrap;
}
.modal-body { display: flex; flex-direction: column; gap: 24rpx; }
.modal-row { display: flex; align-items: flex-start; gap: 16rpx; }
.modal-icon { font-size: 32rpx; width: 44rpx; text-align: center; }
.modal-info { flex: 1; }
.modal-label { font-size: 20rpx; color: #999; font-weight: 700; display: block; }
.modal-value { font-size: 26rpx; color: #333; margin-top: 2rpx; }
.modal-footer { display: flex; gap: 16rpx; margin-top: 36rpx; }
.modal-footer button { flex: 1; font-size: 26rpx; font-weight: 600; border: none; }

/* === 空课表遮罩 === */
.empty-schedule-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(255,255,255,0.93);
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
}
.empty-schedule-text { text-align: center; padding: 40rpx; }
.empty-schedule-icon { font-size: 80rpx; display: block; margin-bottom: 20rpx; }
.empty-schedule-title { font-size: 32rpx; font-weight: 700; color: #333; display: block; margin-bottom: 12rpx; }
.empty-schedule-desc { font-size: 26rpx; color: #999; display: block; margin-bottom: 32rpx; }
.empty-schedule-btn { display: inline-block; background: #4A90D9; color: #fff; padding: 18rpx 60rpx; border-radius: 40rpx; font-size: 28rpx; font-weight: 600; }
.empty-schedule-btn:active { opacity: 0.85; }

/* === 首次登录提示卡片 === */
.login-tip-card {
  width: 560rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx 36rpx;
  text-align: center;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.12);
}
.login-tip-icon { font-size: 80rpx; display: block; margin-bottom: 20rpx; }
.login-tip-title { font-size: 34rpx; font-weight: 700; color: #191c1e; display: block; margin-bottom: 12rpx; }
.login-tip-desc { font-size: 26rpx; color: #888; display: block; line-height: 1.5; margin-bottom: 36rpx; }
.login-tip-actions { display: flex; gap: 20rpx; justify-content: center; }
.login-tip-cancel { padding: 20rpx 40rpx; background: #f2f4f7; color: #666; border-radius: 40rpx; font-size: 28rpx; }
.login-tip-confirm { padding: 20rpx 40rpx; background: #4A90D9; color: #fff; border-radius: 40rpx; font-size: 28rpx; font-weight: 600; }
.login-tip-cancel:active, .login-tip-confirm:active { opacity: 0.8; }
