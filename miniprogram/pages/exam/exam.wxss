/** 考试安排页面 **/
.page-container {
  padding: 16rpx;
  padding-bottom: 40rpx;
  min-height: 100vh;
  background: #f7f9fc;
}

/* 分区 */
.section { margin-bottom: 32rpx; }
.section-past { opacity: 0.55; }

.section-header {
  display: flex; align-items: center; gap: 10rpx;
  padding: 0 4rpx 12rpx;
}
.section-dot {
  width: 14rpx; height: 14rpx; border-radius: 50%;
}
.dot-today { background: #4A90D9; }
.dot-upcoming { background: #999; }
.dot-past { background: #ccc; }
.section-title { font-size: 30rpx; font-weight: 700; color: #333; flex: 1; }
.section-date { font-size: 24rpx; color: #999; }

/* 日期分组头 */
.date-head {
  padding: 16rpx 4rpx 10rpx;
}
.date-text { font-size: 24rpx; color: #999; }

/* 考试卡片 */
.exam-card {
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 20rpx;
  border-left: 6rpx solid #4A90D9;
}
.card-today { background: #f0f5fc; }
.card-past { border-left-color: #ccc; }

.exam-top {
  display: flex; justify-content: space-between; align-items: flex-start;
}
.exam-info { flex: 1; min-width: 0; }
.exam-course {
  font-size: 32rpx; font-weight: 700; color: #191c1e;
  display: block; margin-bottom: 6rpx;
}
.exam-location {
  font-size: 24rpx; color: #888;
}
.exam-time { text-align: right; flex-shrink: 0; }
.exam-time-text {
  font-size: 28rpx; font-weight: 600; color: #4A90D9; display: block;
}
.card-past .exam-time-text { color: #999; }
.exam-status {
  font-size: 22rpx; margin-top: 4rpx; display: block;
}
.status-active { color: #4A90D9; font-weight: 600; }
.status-past { color: #bbb; }
.exam-countdown { font-size: 22rpx; color: #999; margin-top: 4rpx; display: block; }

.exam-divider {
  height: 1rpx; background: #e8ecf1; margin: 16rpx 0;
}

.exam-bottom {
  display: flex; align-items: center; gap: 16rpx;
  font-size: 24rpx; color: #888;
}
.exam-teacher, .exam-class { font-size: 24rpx; }
.exam-tag {
  margin-left: auto;
  padding: 4rpx 16rpx; border-radius: 12rpx;
  background: #e8f0fa; color: #4A90D9;
  font-size: 22rpx; font-weight: 600;
}

/* 空状态 */
.empty-state {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; padding: 200rpx 0;
}
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #ccc; }
