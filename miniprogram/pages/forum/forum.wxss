/** 论坛页面样式 **/
.page-container {
  padding-bottom: 120rpx;
}

/* 搜索栏 */
.search-bar {
  padding: 16rpx 24rpx;
}
.search-input-wrap {
  display: flex;
  align-items: center;
  background: #f2f4f7;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  gap: 12rpx;
}
.search-icon {
  font-size: 32rpx;
}
.search-input {
  flex: 1;
  font-size: 28rpx;
  background: transparent;
}
.search-clear {
  font-size: 28rpx;
  color: #999;
  padding: 8rpx;
}

/* 排序栏 */
.sort-bar {
  display: flex;
  padding: 0 24rpx 16rpx;
  gap: 20rpx;
}
.sort-item {
  font-size: 26rpx;
  color: #999;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  background: #f2f4f7;
  font-weight: 500;
}
.sort-item.active {
  background: #4A90D9;
  color: #fff;
  font-weight: 700;
}

/* 帖子卡片 */
.post-list {
  padding: 0 16rpx;
}
.post-card {
  padding: 24rpx;
}
.post-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.post-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #4A90D9;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  flex-shrink: 0;
}
.post-author-info {
  flex: 1;
}
.post-author {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
}
.post-time {
  font-size: 22rpx;
  color: #999;
}
.post-pin {
  font-size: 22rpx;
  color: #ff6b6b;
  font-weight: 600;
  background: #fff0f0;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}
.post-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #191c1e;
  margin-bottom: 12rpx;
  line-height: 1.4;
}
.post-excerpt {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  margin-bottom: 16rpx;
}
.post-actions {
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f2f5;
}
.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.action-icon {
  font-size: 28rpx;
}
.action-count {
  font-size: 24rpx;
  color: #999;
}
.action-time {
  margin-left: auto;
  font-size: 22rpx;
  color: #bbb;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
.empty-text {
  font-size: 28rpx;
  color: #bbb;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}

/* FAB 发帖按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 140rpx;
  width: 100rpx;
  height: 100rpx;
  background: #4A90D9;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.4);
  z-index: 50;
}
.fab:active {
  transform: scale(0.9);
}
.fab-icon {
  font-size: 50rpx;
  font-weight: 300;
}

/* 发帖弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.35);
  backdrop-filter: blur(6rpx);
  z-index: 200;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}
.modal-mask.show {
  opacity: 1;
  visibility: visible;
}
.modal-content {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  max-height: 80vh;
  overflow-y: auto;
}
.editor-modal {
  animation: slideUp 0.3s ease;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}
.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #191c1e;
}
.modal-close {
  font-size: 32rpx;
  color: #999;
  padding: 8rpx;
}
.editor-body {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.editor-title-input {
  background: #f2f4f7;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  font-weight: 600;
}
.editor-content-input {
  background: #f2f4f7;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  min-height: 200rpx;
}
.modal-footer {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}
.modal-footer button {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
}
