/** 全局样式 **/
page {
  height: 100%;
  background-color: #f7f9fc;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #191c1e;
  box-sizing: border-box;
}

/* 主色调工具类 */
.text-primary { color: #4A90D9; }
.bg-primary { background-color: #4A90D9; }
.text-muted { color: #999; }
.text-sub { color: #666; }

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(74, 144, 217, 0.08);
  padding: 24rpx;
  margin-bottom: 20rpx;
}

/* 按钮样式 */
.btn-primary {
  background-color: #4A90D9;
  color: #fff;
  border-radius: 24rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-weight: 600;
  font-size: 30rpx;
  border: none;
}
.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.btn-outline {
  background: #f0f4f9;
  color: #4A90D9;
  border-radius: 24rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-weight: 600;
  font-size: 30rpx;
  border: none;
}

/* 圆角头像 */
.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #e0e3e6;
}

/* 输入框 */
.input-field {
  background: #f2f4f7;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}
